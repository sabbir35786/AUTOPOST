{
  "crons": [
    {
      "path": "/backend/api/internal/run-scheduler",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "https://autopost-qwgw.onrender.com/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "https://autopost-qwgw.onrender.com"
  }
}
