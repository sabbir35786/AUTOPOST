# Database Configuration
# Local SQLite:
DATABASE_URL=sqlite:///./test.db
#
# Supabase/PostgreSQL:
# Recommended for Windows/local development: Supabase Transaction pooler.
# Supabase Dashboard -> Project Settings -> Database -> Connection string ->
# Transaction pooler. Paste the full URI below and replace [YOUR-PASSWORD]
# with your database password.
# DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DATABASE-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres
#
# Direct Supabase URI also works only if your network can resolve/reach it:
# DATABASE_URL=postgresql://postgres:YOUR-DATABASE-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Security Configuration
SECRET_KEY=your-super-secret-key-change-me

# OAuth / Third-party Integrations
# Optional fallback. Users can enter these in the dashboard instead.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://autopost-qwgw.onrender.com/auth/facebook/callback
FACEBOOK_TOKEN_ENCRYPTION_KEY=change-this-to-a-long-random-secret
FACEBOOK_OAUTH_SCOPES=pages_manage_posts,pages_read_engagement,pages_show_list
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
FAL_API_KEY=
STABILITY_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Frontend Configuration
FRONTEND_URL=https://autopost-woad.vercel.app
