# Database Configuration (PostgreSQL required — SQLite is blocked in config.py)
# For local dev, use a free Supabase project or local PostgreSQL.
# Supabase Transaction pooler (recommended):
# DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres
#
# Direct Supabase URI:
# DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Security Configuration
# Generate a permanent key with: python -c "import secrets; print(secrets.token_hex(32))"
# This MUST be set — the app will not start without it.
SECRET_KEY=your-super-secret-key-change-me
# Token expiration time in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OAuth / Third-party Integrations
# Platform API keys (users pick Mistral or Gemini in Settings; keys stay on the server).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://auto-poster-backend.onrender.com/auth/facebook/callback
FACEBOOK_TOKEN_ENCRYPTION_KEY=change-this-to-a-long-random-secret
FACEBOOK_OAUTH_SCOPES=pages_manage_posts,pages_read_engagement,pages_show_list
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
FAL_API_KEY=
STABILITY_API_KEY=
# From https://aistudio.google.com/apikey (alias: GOOGLE_API_KEY)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Frontend / Backend URLs
FRONTEND_URL=https://autopost-woad.vercel.app
BACKEND_URL=https://auto-poster-backend.onrender.com

# Cron endpoint security (used by the QStash → run-scheduler endpoint)
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(24))"
CRON_SECRET=your-random-cron-secret

# ─── Upstash QStash (Scheduled Post Delivery) ───────────────────────────────
# Sign up at https://console.upstash.com/ → QStash → your project.
#
# QSTASH_TOKEN        : found under QStash → "TOKEN" in the dashboard.
# QSTASH_CURRENT_SIGNING_KEY / QSTASH_NEXT_SIGNING_KEY :
#     found under QStash → "Signing Keys" — used to verify every incoming
#     webhook request so only real QStash messages are processed.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
